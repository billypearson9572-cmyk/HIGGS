# Copy this file to `.env.local` for local development, and set the same
# values in your host's environment variables (e.g. Vercel) for production.

# --- Contact form delivery -------------------------------------------------

# Recommended: Web3Forms. Get a free access key at https://web3forms.com by
# entering info@voltaradigital.com — they'll email you the key. Paste it here
# and contact-form submissions are emailed straight to that inbox.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Alternative: a generic JSON form endpoint (e.g. Formspree). Only used if the
# Web3Forms key above is not set.
NEXT_PUBLIC_CONTACT_ENDPOINT=

# --- Search engine verification (optional, set at launch) ------------------

# Google Search Console: add a property for voltaradigital.com, choose the
# "HTML tag" method, and paste just the content="..." value here. Then submit
# https://voltaradigital.com/sitemap.xml under Sitemaps.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools: same idea — paste the meta-tag content value here.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
